{
  "compilerOptions": {
    "lib": ["es2021"],
    "target": "es2021",
    "allowJs": true,
    "esModuleInterop": true,
    "module": "Node16",
    "moduleResolution": "Node16",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "declaration": false,
    "sourceMap": false,
    "outDir": "./.medusa/server",
    "rootDir": "./",
    "baseUrl": ".",
    "jsx": "react-jsx",
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "checkJs": false,
  },
  "ts-node": {
    "swc": true,
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "medusa-config.ts",
    "env.d.ts", // Add this line
  ],
  "exclude": [
    "**/__tests__",
    "**/__fixtures__",
    "node_modules",
    ".medusa/server",
    ".medusa/admin",
    ".cache",
  ],
}
